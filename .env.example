# ─────────────────────────────────────────────────
# ALTRO ERP — Environment Variables Template
# ─────────────────────────────────────────────────
# Salin file ini menjadi .env.local dan isi dengan
# nilai dari Supabase Dashboard → Settings → API
#
# PENTING: Jangan commit .env.local ke git!
# Pastikan .env.local ada di .gitignore
# ─────────────────────────────────────────────────

# URL project Supabase Anda
# Ditemukan di: Supabase Dashboard → Settings → API → Project URL
# Contoh: https://abcdefghijklmn.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key dari Supabase
# GUNAKAN "anon public" key, BUKAN "service_role" key!
# Ditemukan di: Supabase Dashboard → Settings → API → Project API keys
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
